{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../config/.env run --hot src/index.ts",
    "start": "bun run ./dist/index.js",
    "build": "bun build --target bun src/index.ts --minify --outdir ./dist",
    "stressTest": "artillery run ../../stress-test.yml",
    "build:lambda": "bun build --target node src/lambda.ts --minify --outfile ./dist/lambda.mjs"
  },
  "dependencies": {
    "shared": "workspace:*",
    "@hono/zod-validator": "^0.7.2",
    "hono": "^4.9.4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
