{
  "name": "notification-service",
  "scripts": {
    "dev": "bun --env-file=./config/api.env.example --env-file=./config/db.env.example run --hot src/index.ts",
    "start": "bun run ./dist/index.js",
    "build": "bun build --target bun src/index.ts --minify --outdir ./dist",
    "migrate": "bun prisma migrate",
    "typecheck": "bun run tsc",
    "stressTest": "artillery run stress-test.yml"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@hono/zod-validator": "^0.7.2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/pg": "^8.16.0",
    "dotenv": "^17.2.1",
    "hono": "^4.9.4",
    "ioredis": "^5.7.0",
    "pino": "^9.9.1",
    "pino-loki": "^2.6.0",
    "pino-pretty": "^13.1.1",
    "prom-client": "^15.1.3",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "artillery": "^2.0.24",
    "prisma": "^7.3.0"
  }
}
