{
  "name": "notification-service",
  "scripts": {
    "dev": "bun --filter \"{api,worker}\" dev",
    "start": "bun --filter \"{api,worker}\" start",
    "build": "bun --filter \"*\" build",
    "migrate:dev": "bun --env-file=./config/db.env.example --env-file=./config/api.env.example prisma migrate dev",
    "migrate:deploy": "bun --env-file=./config/db.env.example --env-file=./config/api.env.example prisma migrate deploy",
    "typecheck": "bun run tsc",
    "stressTest": "bun --filter api stressTest"
  },
  "dependencies": {},
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "artillery": "^2.0.24",
    "pino-pretty": "^13.1.1",
    "prisma": "^7.3.0",
    "typescript": "^5.0.0"
  }
}
