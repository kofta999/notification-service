{
  "name": "notification-service",
  "type": "module",
  "scripts": {
    "dev": "bun --filter \"{api,worker}\" dev",
    "start": "bun --filter \"{api,worker}\" start",
    "build": "bun --filter \"*\" build",
    "deploy": "bun --filter worker build && bun cdk deploy",
    "typecheck": "bun run tsc",
    "stressTest": "bun --filter api stressTest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1014.0",
    "@aws-sdk/client-sqs": "",
    "@aws-sdk/lib-dynamodb": "^3.1014.0",
    "@types/bun": "latest",
    "dotenv": "^17.2.1",
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.5.1",
    "pino-pretty": "^13.1.1",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.0",
    "artillery": "^2.0.24",
    "aws-cdk": "^2.1112.0",
    "ts-node": "^10.9.2"
  }
}
